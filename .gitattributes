# Normalize line endings to LF in the repository; checkout as-is on Windows
* text=auto eol=lf

# Force binary treatment for generated/binary files
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.pdf  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.otf  binary
*.zip  binary
*.gz   binary
*.pyc  binary
