# =============================================================================
#  Yuno AI Agentic — root .gitignore
#  Covers: frontend (Vite/React), backend (Node.js), agent-runtime (Python)
# =============================================================================


# ── Environment variables ─────────────────────────────────────────────────────
# Never commit secrets. Copy .env.example → .env and fill in your values.
.env
.env.*
!.env.example          # keep the example template (root)
!**/.env.example       # keep the example template (subdirs)
.env.local
.env.development
.env.development.local
.env.test
.env.test.local
.env.production
.env.production.local
.env.staging


# ── Node / npm / pnpm / yarn ──────────────────────────────────────────────────
node_modules/
frontend/node_modules/
backend/node_modules/

# Lock files — keep package-lock.json / yarn.lock; ignore only pnpm store
.pnpm-store/

# npm/yarn/pnpm debug logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
.pnpmfile.cjs


# ── Build outputs ─────────────────────────────────────────────────────────────
dist/
build/
out/
.output/
frontend/dist/
frontend/build/
backend/dist/
backend/build/


# ── Vite / frontend caches ────────────────────────────────────────────────────
frontend/.vite/
frontend/.vite-cache/
.vite/
*.local          # vite auto-creates *.local override files


# ── TypeScript build artefacts ────────────────────────────────────────────────
*.tsbuildinfo
tsconfig.tsbuildinfo


# ── Testing ───────────────────────────────────────────────────────────────────
coverage/
.nyc_output/
*.lcov
test-results/
playwright-report/
.jest-cache/


# ── Python — virtual environment ──────────────────────────────────────────────
agent-runtime/venv/
agent-runtime/.venv/
venv/
.venv/
env/
.env/          # Python convention (different from .env file above)
ENV/
env.bak/
venv.bak/


# ── Python — bytecode & caches ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
.Python

# Pytest / coverage
.pytest_cache/
.coverage
.coverage.*
htmlcov/
nosetests.xml
coverage.xml
*.cover

# MyPy / Pyright
.mypy_cache/
.dmypy.json
dmypy.json
.pyright/

# Distribution / packaging
*.egg-info/
*.egg
MANIFEST
dist/
build/
.eggs/
*.whl
pip-wheel-metadata/


# ── Agent-runtime workspace (user uploads & runtime data) ────────────────────
# These are generated at runtime — do not commit user files or token logs.
agent-runtime/workspace/uploads/
agent-runtime/workspace/token_usage.json
agent-runtime/workspace/*.db
agent-runtime/workspace/*.json
# Cloned repos inside workspace (embedded git repos)
agent-runtime/workspace/small_projects/
# But DO track the workspace folder itself so git creates it on clone
!agent-runtime/workspace/.gitkeep


# ── Database files ────────────────────────────────────────────────────────────
*.db
*.sqlite
*.sqlite3
*.db-wal
*.db-shm
*.db-journal


# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
*.log.*
log/


# ── OS artefacts ─────────────────────────────────────────────────────────────
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
desktop.ini
$RECYCLE.BIN/
*.lnk

# Linux
*~


# ── IDE / editor ──────────────────────────────────────────────────────────────
.vscode/*
!.vscode/extensions.json   # share recommended extensions
!.vscode/settings.json     # share workspace settings (no secrets)
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?
.project
.classpath
.c9/
*.launch
.settings/


# ── Misc tooling ──────────────────────────────────────────────────────────────
.eslintcache
.stylelintcache
.cache/
.parcel-cache/
.turbo/
.vercel/
.netlify/
storybook-static/
.docusaurus/
